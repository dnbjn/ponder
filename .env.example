# Select port (default: 3000) and profile
PORT=42069
# Powers Ethereum mainnet, plus an automatic fallback on the L2 chains.
# L2 primary traffic goes to keyless public RPCs (PublicNode), so they stay off the Alchemy CU budget.
ALCHEMY_RPC_KEY=...

# (Optional) Postgres database URL. If not provided, SQLite will be used.
DATABASE_URL=...

# Indexing control
MAX_REQUESTS_PER_SECOND=10
POLLING_INTERVAL_MS=30000
